---
import pharmData from '../data/pharmacies.json';

interface Props {
  // Add props if needed
}

// Lógica para determinar la farmacia de guardia hoy
const now = new Date();
const config = { 
  timeZone: 'Europe/Madrid', 
  year: 'numeric', 
  month: 'numeric', 
  day: 'numeric', 
  hour: 'numeric', 
  minute: 'numeric', 
  hour12: false 
};

// @ts-ignore
const formatter = new Intl.DateTimeFormat('es-ES', config);
const parts = formatter.formatToParts(now);
const getPart = (type: string) => parts.find(p => p.type === type)?.value || '';

let dayInt = parseInt(getPart('day'));
let monthInt = parseInt(getPart('month'));
let yearInt = parseInt(getPart('year'));
const hourInt = parseInt(getPart('hour'));
const minuteInt = parseInt(getPart('minute'));

if (hourInt < 9 || (hourInt === 9 && minuteInt < 30)) {
  const yesterday = new Date(now);
  yesterday.setDate(yesterday.getDate() - 1);
  const yParts = formatter.formatToParts(yesterday);
  const getYPart = (type: string) => yParts.find(p => p.type === type)?.value || '';
  dayInt = parseInt(getYPart('day'));
  monthInt = parseInt(getYPart('month'));
  yearInt = parseInt(getYPart('year'));
}

const isApril2026 = monthInt === 4 && yearInt === 2026;
const pharmacyKey = isApril2026 ? pharmData.calendar.days[dayInt.toString() as keyof typeof pharmData.calendar.days] : null;
const activePharmacy = pharmacyKey ? pharmData.pharmacies[pharmacyKey as keyof typeof pharmData.pharmacies] : null;

// Extraer un nombre corto para el botón
const displayName = activePharmacy 
  ? activePharmacy.name.split('(')[0].replace('Farmacia ', '').trim() 
  : 'Guardia Hoy';
---

<header class="fixed top-0 z-50 w-full px-4 sm:px-6 lg:px-8 pt-4 pb-4" transition:persist="navbar">
  <nav class="glass-panel mx-auto max-w-7xl flex items-center justify-between px-6 py-4 shadow-xl shadow-black/5">
    <a href="/" class="flex items-center gap-3 group">
      <img
        src="/logo.png"
        alt="Logo"
        class="w-10 h-10 transition-transform group-hover:scale-110"
      />
      <span class="text-xl font-bold text-primary tracking-tight">
        Cantillana<span class="text-secondary">Digital</span>
      </span>
    </a>
    
    <div class="hidden md:flex items-center gap-8 text-[15px]">
      <a href="/" class="font-bold text-slate-600 hover:text-primary transition-all">Inicio</a>
      <a href="/transporte" class="font-bold text-slate-600 hover:text-primary transition-all">Transporte</a>
      <a href="/punto-limpio" class="font-bold text-slate-600 hover:text-primary transition-all">Punto Limpio</a>
      <a href="/farmacia" class="btn-primary py-2 px-5 text-[13px] flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-white animate-pulse"></span>
        Guardia: {displayName}
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-button"
      class="md:hidden p-2 text-slate-600 hover:text-primary transition-colors relative z-[60]"
      aria-label="Alternar menú"
    >
      <div id="icon-menu" class="transition-all duration-300 transform scale-100 opacity-100">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
        </svg>
      </div>
      <div id="icon-close" class="absolute inset-0 p-2 transition-all duration-300 transform scale-50 opacity-0 rotate-90">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </div>
    </button>
  </nav>

  <!-- Mobile Menu Drawer -->
  <div
    id="mobile-menu"
    class="hidden opacity-0 -translate-y-4 md:hidden mt-3 mx-auto max-w-7xl glass-panel p-8 shadow-2xl transition-all duration-300 ease-out z-50 pointer-events-none"
  >
    <div class="flex flex-col gap-8">
      <a href="/" class="mobile-link text-xl font-black text-slate-600 hover:text-primary transition-colors border-b-2 border-slate-100 pb-3">Inicio</a>
      <a href="/transporte" class="mobile-link text-xl font-black text-slate-600 hover:text-primary transition-colors border-b-2 border-slate-100 pb-3">Transporte</a>
      <a href="/punto-limpio" class="mobile-link text-xl font-black text-slate-600 hover:text-primary transition-colors border-b-2 border-slate-100 pb-3">Punto Limpio</a>
      <a href="/farmacia" class="mobile-link btn-primary justify-center py-5 text-base flex items-center gap-3">
        <span class="w-3 h-3 rounded-full bg-white animate-pulse shadow-[0_0_10px_white]"></span>
        Guardia: {displayName}
      </a>
    </div>
  </div>
</header>

<script is:inline>
  function setupMenu() {
    const menuButton = document.getElementById("mobile-menu-button");
    const mobileMenu = document.getElementById("mobile-menu");
    const mobileLinks = document.querySelectorAll(".mobile-link");

    if (!menuButton || !mobileMenu) return;

    let isOpen = false;

    // Clean up old listener if exists by cloning
    const newBtn = menuButton.cloneNode(true);
    menuButton.parentNode.replaceChild(newBtn, menuButton);

    // Re-select internal icons from the new button
    const newIconMenu = newBtn.querySelector("#icon-menu");
    const newIconClose = newBtn.querySelector("#icon-close");

    function toggleMenu() {
      isOpen = !isOpen;
      
      if (isOpen) {
        // OPEN
        mobileMenu.classList.remove("hidden");
        // Wait for next frame to start animation
        requestAnimationFrame(() => {
          mobileMenu.classList.remove("opacity-0", "-translate-y-4", "pointer-events-none");
          mobileMenu.classList.add("opacity-100", "translate-y-0", "pointer-events-auto");
          
          newIconMenu.classList.remove("scale-100", "opacity-100", "rotate-0");
          newIconMenu.classList.add("scale-50", "opacity-0", "-rotate-90");
          
          newIconClose.classList.remove("scale-50", "opacity-0", "rotate-90");
          newIconClose.classList.add("scale-100", "opacity-100", "rotate-0");
        });
      } else {
        // CLOSE
        mobileMenu.classList.remove("opacity-100", "translate-y-0", "pointer-events-auto");
        mobileMenu.classList.add("opacity-0", "-translate-y-4", "pointer-events-none");
        
        newIconMenu.classList.remove("scale-50", "opacity-0", "-rotate-90");
        newIconMenu.classList.add("scale-100", "opacity-100", "rotate-0");
        
        newIconClose.classList.remove("scale-100", "opacity-100", "rotate-0");
        newIconClose.classList.add("scale-50", "opacity-0", "rotate-90");
        
        // Wait for transition to finish before hiding
        setTimeout(() => {
          if (!isOpen) mobileMenu.classList.add("hidden");
        }, 300);
      }
    }

    newBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      toggleMenu();
    });

    // Close when clicking a link
    mobileLinks.forEach(link => {
      link.addEventListener("click", () => {
        if (isOpen) toggleMenu();
      });
    });

    // Close when clicking outside
    document.addEventListener("click", (e) => {
      if (isOpen && !mobileMenu.contains(e.target) && !newBtn.contains(e.target)) {
        toggleMenu();
      }
    });
  }

  // Initial load
  setupMenu();
  // Support for View Transitions
  document.addEventListener("astro:after-swap", setupMenu);
</script>
