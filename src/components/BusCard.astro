---
interface Props {
  bus: any;
}

const { bus } = Astro.props;
---

<div class="bus-card glass-panel p-8 animate-fade flex flex-col gap-6" id={`bus-${bus.id}`}>
  <div class="flex items-center gap-4">
    <div class="bg-primary text-white w-12 h-12 rounded-xl flex items-center justify-center shadow-md">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 6h8"/><path d="M6 10h12"/><path d="M11 18h2"/><path d="M4 18V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v10"/><path d="M2 18h20"/><circle cx="7" cy="10" r="1"/><circle cx="17" cy="10" r="1"/></svg>
    </div>
    <div>
      <h3 class="text-xl font-bold text-slate-800">{bus.name}</h3>
      <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider">{bus.operator}</p>
    </div>
  </div>

  <div class="bg-linear-to-br from-primary to-primary-light text-white p-6 rounded-2xl text-center shadow-lg shadow-primary/20">
    <span class="text-[0.7rem] font-bold tracking-[0.15em] opacity-80 uppercase">PRÓXIMO AUTOBÚS</span>
    <div class="mt-2 flex flex-col gap-1" data-bus-id={bus.id} id={`display-${bus.id}`}>
      <span class="time text-4xl font-extrabold leading-tight">Cargando...</span>
      <span class="countdown text-sm font-medium opacity-90">calculando</span>
    </div>
  </div>

  <div class="text-sm text-slate-600 pl-4 border-l-4 border-secondary/60 leading-relaxed italic">
    <p>{bus.info}</p>
  </div>

  <div class="space-y-8">
    {bus.schedules.map((schedule: any) => (
      <div class="schedule-section">
        <h4 class="bg-slate-100 px-4 py-2 rounded-lg text-xs font-bold text-slate-600 mb-6 uppercase tracking-wide">{schedule.days}</h4>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {Object.entries(schedule.directions).map(([direction, times]: [string, any]) => (
            <div>
              <span class="block text-sm font-bold text-primary mb-4">{direction}</span>
              <div class="flex flex-wrap gap-2" data-times={JSON.stringify(times)} data-days={schedule.days} data-direction={direction}>
                {times.map((time: string) => (
                  <span class="bg-white px-3 py-1.5 rounded-md text-sm font-bold border border-slate-100 text-slate-700 shadow-xs hover:border-secondary transition-colors cursor-default">
                    {time}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</div>

<script is:inline>
  function initBusCard() {
    function updateBusTimes() {
      const now = new Date();
      const currentDay = now.getDay();
      const currentTime = now.getHours() * 60 + now.getMinutes();

      document.querySelectorAll('[data-bus-id]').forEach(display => {
        const busId = display.getAttribute('data-bus-id');
        const card = display.closest('.bus-card');
        if (!card) return;

        const timeLists = card.querySelectorAll('[data-times]');
        let nextTime = null;
        let nextDirection = "";

        timeLists.forEach(list => {
          const days = list.getAttribute('data-days');
          const times = JSON.parse(list.getAttribute('data-times') || '[]');
          const direction = list.getAttribute('data-direction');
          
          const isWeekend = currentDay === 0 || currentDay === 6;
          const isTargetWeekend = days?.includes('Sábados');
          
          if ((isWeekend && isTargetWeekend) || (!isWeekend && !isTargetWeekend)) {
            for (const timeStr of times) {
              const [h, m] = timeStr.split(':').map(Number);
              const busTimeMinutes = h * 60 + m;
              
              if (busTimeMinutes > currentTime) {
                if (nextTime === null || busTimeMinutes < nextTime.minutes) {
                  nextTime = { str: timeStr, minutes: busTimeMinutes };
                  nextDirection = direction || "";
                }
              }
            }
          }
        });

        const timeElement = display.querySelector('.time');
        const countdownElement = display.querySelector('.countdown');

        if (nextTime && timeElement && countdownElement) {
          timeElement.textContent = nextTime.str;
          const diff = nextTime.minutes - currentTime;
          const h = Math.floor(diff / 60);
          const m = diff % 60;
          countdownElement.textContent = diff < 60 ? `en ${m} min (${nextDirection})` : `en ${h}h ${m}m (${nextDirection})`;
        } else if (timeElement && countdownElement) {
          timeElement.textContent = "--:--";
          countdownElement.textContent = "Servicio finalizado por hoy";
        }
      });
    }

    updateBusTimes();
    // Clear and set interval to avoid multiple timers
    if (window.busInterval) clearInterval(window.busInterval);
    window.busInterval = setInterval(updateBusTimes, 30000);
  }

  // Initial load
  initBusCard();
  // Support for View Transitions
  document.addEventListener('astro:after-swap', initBusCard);
</script>
