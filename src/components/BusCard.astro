---
interface Props {
  bus: any;
}

const { bus } = Astro.props;
---

<div class="bus-card glass-panel p-8 animate-fade flex flex-col gap-6" id={`bus-${bus.id}`}>
  <div class="flex items-center gap-4">
    <div class="bg-primary text-white w-12 h-12 rounded-xl flex items-center justify-center shadow-md">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 6h8"/><path d="M6 10h12"/><path d="M11 18h2"/><path d="M4 18V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v10"/><path d="M2 18h20"/><circle cx="7" cy="10" r="1"/><circle cx="17" cy="10" r="1"/></svg>
    </div>
    <div>
      <h3 class="text-xl font-bold text-slate-800">{bus.name}</h3>
      <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider">{bus.operator}</p>
    </div>
  </div>

  <div class="bg-linear-to-br from-primary to-primary-light text-white p-6 rounded-2xl text-center shadow-lg shadow-primary/20">
    <span class="text-[0.7rem] font-bold tracking-[0.15em] opacity-80 uppercase">PRÓXIMO AUTOBÚS</span>
    <div class="mt-2 flex flex-col gap-1" data-bus-id={bus.id} id={`display-${bus.id}`}>
      <span class="time text-4xl font-extrabold leading-tight">Cargando...</span>
      <span class="countdown text-sm font-medium opacity-90">calculando</span>
    </div>
  </div>

  <div class="text-sm text-slate-600 pl-4 border-l-4 border-secondary/60 leading-relaxed italic">
    <p>{bus.info}</p>
  </div>

  {/* Aviso de Feria */}
  <div class="feria-notice hidden bg-linear-to-r from-amber-50 to-orange-50 border border-amber-200 rounded-2xl p-5 shadow-sm">
    <div class="flex items-start gap-3 mb-4">
      <span class="text-2xl">🎡</span>
      <div>
        <p class="text-sm font-black text-amber-900 uppercase tracking-tight">Servicios Especiales Feria 2026</p>
        <p class="text-xs text-amber-800 font-medium opacity-90 status-text">Cargando info...</p>
      </div>
    </div>
    
    <div class="grid grid-cols-1 gap-3 border-t border-amber-200/50 pt-4">
      <p class="text-[10px] font-bold text-amber-900/40 uppercase tracking-widest mb-1">Horarios Autobús Especial:</p>
      <div class="grid grid-cols-2 gap-4">
        <div class="space-y-2">
          <p class="text-[11px] font-bold text-amber-900">Salidas Cantillana:</p>
          <ul class="text-[10px] text-amber-800 space-y-1">
            <li><strong>Jueves 23:</strong> 16:00h</li>
            <li><strong>Viernes 24:</strong> 16:00h y 23:00h</li>
            <li><strong>Sábado 25:</strong> 16:00h</li>
          </ul>
        </div>
        <div class="space-y-2">
          <p class="text-[11px] font-bold text-amber-900">Regresos (Feria):</p>
          <ul class="text-[10px] text-amber-800 space-y-1">
            <li><strong>Vie 24:</strong> 00:30h y 08:00h</li>
            <li><strong>Sáb 25:</strong> 00:30h y 06:00h</li>
            <li><strong>Dom 26:</strong> 01:00h</li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <div class="space-y-8">
    {bus.schedules.map((schedule: any) => {
      const directions = Object.keys(schedule.directions);
      return (
        <div class="schedule-section">
          <h4 class="bg-slate-100 px-4 py-2 rounded-lg text-xs font-bold text-slate-600 mb-6 uppercase tracking-wide">{schedule.days}</h4>
          
          <!-- Selector de Sentido Interno -->
          <div class="direction-switcher flex gap-2 mb-6 p-1 bg-slate-100/50 rounded-xl border border-slate-200 w-fit">
            {directions.map((dir, idx) => (
              <button 
                class={`px-4 py-2 text-[0.65rem] font-bold rounded-lg transition-all direction-btn ${idx === 0 ? 'active bg-white shadow-sm text-primary' : 'text-slate-500 hover:bg-white/50'}`}
                data-dir-target={dir}
              >
                {dir}
              </button>
            ))}
          </div>

          <div class="directions-container relative">
            {Object.entries(schedule.directions).map(([direction, times]: [string, any], idx) => (
              <div 
                class={`direction-content transition-all duration-300 ${idx === 0 ? 'block opacity-100 translate-x-0' : 'hidden opacity-0 translate-x-4'}`}
                data-direction-name={direction}
              >
                <div class="flex flex-wrap gap-2" data-times={JSON.stringify(times)} data-days={schedule.days} data-direction={direction}>
                  {times.map((time: string) => (
                    <span class="bg-white px-3 py-1.5 rounded-md text-sm font-bold border border-slate-100 text-slate-700 shadow-xs hover:border-secondary transition-colors cursor-default">
                      {time}
                    </span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      );
    })}
  </div>
</div>

<script is:inline>
  function initBusCard() {
    function updateBusTimes() {
      const now = new Date();
      
      // Configuración de Festivos Especiales (Feria 2026)
      const FERIA_DATES = ['2026-04-21', '2026-04-22', '2026-04-23', '2026-04-24', '2026-04-25', '2026-04-26'];
      const SPECIAL_HOLIDAYS = ['2026-04-22']; // Solo el miércoles es festivo oficial en Sevilla
      
      const todayStr = now.getFullYear() + '-' + String(now.getMonth() + 1).padStart(2, '0') + '-' + String(now.getDate()).padStart(2, '0');
      const isFeria = FERIA_DATES.includes(todayStr);
      const isSpecialHoliday = SPECIAL_HOLIDAYS.includes(todayStr);

      const currentDay = now.getDay();
      const currentTimeMinutes = now.getHours() * 60 + now.getMinutes();

      document.querySelectorAll('.bus-card').forEach(card => {
        const busId = card.id.replace('bus-', '');
        const display = card.querySelector('[data-bus-id]');
        const nextBusBox = card.querySelector('.bg-linear-to-br');
        if (!display || !nextBusBox) return;

        const activeBtn = card.querySelector('.direction-btn.active');
        const activeDir = activeBtn ? activeBtn.getAttribute('data-dir-target') : null;
        
        const timeLists = card.querySelectorAll('[data-times]');
        let nextTime = null;
        let nextDirection = "";

        // Function to check and update nextTime
        const checkTimes = (times, direction) => {
          for (const timeStr of times) {
            const [h, m] = timeStr.split(':').map(Number);
            const busTimeMinutes = h * 60 + m;
            
            if (busTimeMinutes > currentTimeMinutes) {
              if (nextTime === null || busTimeMinutes < nextTime.minutes) {
                nextTime = { str: timeStr, minutes: busTimeMinutes };
                nextDirection = direction || "";
              }
            }
          }
        };

        // 1. Revisar horarios normales
        timeLists.forEach(list => {
          const days = list.getAttribute('data-days');
          const times = JSON.parse(list.getAttribute('data-times') || '[]');
          const direction = list.getAttribute('data-direction');
          
          if (activeDir && direction !== activeDir) return;

          // El minibús NO se ve afectado por los festivos de Sevilla (Feria)
          const isMinibus = busId === 'minibus';
          const isWeekend = currentDay === 0 || currentDay === 6 || (!isMinibus && isSpecialHoliday);
          const isTargetWeekend = days?.includes('Sábados') || days?.includes('Domingos');
          
          if ((isWeekend && isTargetWeekend) || (!isWeekend && !isTargetWeekend)) {
            checkTimes(times, direction);
          }
        });

        const timeElement = display.querySelector('.time');
        const countdownElement = display.querySelector('.countdown');
        const badgeElement = display.querySelector('.badge-text') || display.parentElement.querySelector('span:first-child');

        if (nextTime && timeElement && countdownElement) {
          timeElement.textContent = nextTime.str;
          const diff = nextTime.minutes - currentTimeMinutes;
          const h = Math.floor(diff / 60);
          const m = diff % 60;
          countdownElement.textContent = diff < 60 ? `en ${m} min (${nextDirection})` : `en ${h}h ${m}m (${nextDirection})`;
        } else if (timeElement && countdownElement) {
          timeElement.textContent = "--:--";
          countdownElement.textContent = "Servicio finalizado hoy";
        }

        // Mostrar aviso de feria si corresponde
        const feriaNotice = card.querySelector('.feria-notice');
        if (feriaNotice) {
          if (isFeria) {
            feriaNotice.classList.remove('hidden');
            const statusText = feriaNotice.querySelector('.status-text');
            if (statusText) {
              if (isSpecialHoliday) {
                statusText.innerHTML = "Hoy se aplica el horario de <strong>Festivos</strong> en el M-216. Revisa el bus especial abajo.";
              } else {
                statusText.innerHTML = "Semana de Feria. El M-216 opera normal, pero hay un bus especial de refuerzo.";
              }
            }
          } else {
            feriaNotice.classList.add('hidden');
          }
        }
      });
    }

    // Handle Direction Switching for all sections
    document.querySelectorAll('.bus-card').forEach(card => {
      card.addEventListener('click', (e) => {
        const btn = e.target.closest('.direction-btn');
        if (!btn) return;

        const targetDir = btn.getAttribute('data-dir-target');
        
        // Sync ALL buttons in this card to the same direction
        card.querySelectorAll('.direction-btn').forEach(b => {
          if (b.getAttribute('data-dir-target') === targetDir) {
            b.classList.add('active', 'bg-white', 'shadow-sm', 'text-primary');
            b.classList.remove('text-slate-500');
          } else {
            b.classList.remove('active', 'bg-white', 'shadow-sm', 'text-primary');
            b.classList.add('text-slate-500');
          }
        });

        // Update ALL schedule sections visibility
        card.querySelectorAll('.direction-content').forEach(content => {
          if (content.getAttribute('data-direction-name') === targetDir) {
            content.classList.remove('hidden', 'opacity-0', 'translate-x-4');
            content.classList.add('block', 'opacity-100', 'translate-x-0');
          } else {
            content.classList.add('hidden', 'opacity-0', 'translate-x-4');
            content.classList.remove('block', 'opacity-100', 'translate-x-0');
          }
        });

        // Update calculations
        updateBusTimes();
      });
    });

    updateBusTimes();
    if (window.busInterval) clearInterval(window.busInterval);
    window.busInterval = setInterval(updateBusTimes, 30000);
  }

  initBusCard();
  document.addEventListener('astro:after-swap', initBusCard);
</script>
