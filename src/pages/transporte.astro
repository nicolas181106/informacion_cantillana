---
import Layout from "../layouts/Layout.astro";
import BusCard from "../components/BusCard.astro";
import busData from "../data/buses.json";

export const prerender = true;
---

<Layout
	title="Transporte"
	description="Consulta horarios de autobuses de Cantillana en tiempo real con nuestra herramienta interactiva."
>
	<!-- Hero Section -->
	<section class="relative bg-primary overflow-hidden pt-36 pb-24 sm:pt-44 sm:pb-32 -mt-2">
		<div class="mx-auto max-w-7xl px-6 lg:px-8 text-center relative z-10">
			<div
				class="inline-flex items-center gap-2 rounded-full px-4 py-1.5 text-xs font-bold uppercase tracking-wider text-secondary bg-white/10 mb-8 border border-white/10 backdrop-blur-sm animate-fade"
			>
				Horarios Actualizados 2026
			</div>
			<h1
				class="text-4xl font-extrabold tracking-tight text-white sm:text-6xl mb-8 leading-tight"
			>
				Moverte por <span class="text-secondary">Cantillana</span><br
				/>nunca fue tan fácil
			</h1>
			<p
				class="mx-auto max-w-2xl text-lg opacity-90 text-slate-100 mb-10 leading-relaxed"
			>
				Consulta los horarios de las líneas que conectan nuestro pueblo con la estación y Sevilla. 
                Información oficial en tiempo real.
			</p>
			<div class="flex flex-col sm:flex-row gap-4 justify-center">
				<a
					href="#transporte"
					class="bg-secondary text-primary px-8 py-4 rounded-full font-bold shadow-xl shadow-secondary/20 hover:-translate-y-1 transition-all"
					>Ver Horarios</a
				>
				<a
					href="/"
					class="bg-white/10 text-white border border-white/20 backdrop-blur-md px-8 py-4 rounded-full font-bold hover:bg-white/20 transition-all"
					>Volver al Inicio</a
				>
			</div>
		</div>
		<!-- Decorative blobs -->
		<div
			class="absolute -top-24 -left-20 w-96 h-96 bg-secondary/10 rounded-full blur-3xl pointer-events-none"
		>
		</div>
		<div
			class="absolute -bottom-24 -right-20 w-96 h-96 bg-primary-light/30 rounded-full blur-3xl pointer-events-none"
		>
		</div>
	</section>

	<!-- Transport Section -->
	<section
		id="transporte"
		class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-20"
	>
		<div class="text-center mb-16 px-4">
			<h2 class="text-3xl font-extrabold text-primary mb-4">
				🚌 Transporte Público
			</h2>
			<p class="text-slate-500 max-w-xl mx-auto">
				Selecciona la línea para ver los horarios detallados de ida y vuelta.
			</p>
		</div>


		<!-- Switcher Moderno -->
		<div class="flex justify-center mb-12 animate-fade">
			<div
				class="relative flex p-1.5 bg-slate-200/50 backdrop-blur-md border border-slate-200 rounded-full w-fit shadow-inner group"
				id="transport-switcher"
			>
				<button
					class="relative z-20 flex-1 px-6 py-3 text-sm font-bold transition-colors switcher-btn active cursor-pointer touch-manipulation"
					data-target="m216">Bus M-216 (Sevilla)</button
				>
				<button
					class="relative z-20 flex-1 px-6 py-3 text-sm font-bold transition-colors switcher-btn cursor-pointer touch-manipulation"
					data-target="minibus">Minibús (Estación)</button
				>
				<div
					class="absolute top-1.5 left-1.5 bottom-1.5 w-[calc(50%-0.375rem)] bg-white rounded-full shadow-lg transition-transform duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] switcher-indicator translate-x-0 pointer-events-none"
					id="indicator"
				>
				</div>
			</div>
		</div>

		<div class="space-y-10">
			<div
				id="content-m216"
				class="tab-content transition-all duration-500 opacity-100 scale-100 block"
			>
				<BusCard bus={busData.m216} />

				<!-- Tarjeta Especial Feria -->
				<div id="feria-special-card" class="hidden mt-10 animate-fade">
					<div class="bg-linear-to-br from-amber-50 to-orange-50 border border-amber-200 rounded-3xl p-8 shadow-xl shadow-amber-200/20 overflow-hidden relative group">
						<!-- Decorative pattern -->
						<div class="absolute -top-10 -right-10 w-40 h-40 bg-amber-200 opacity-20 rounded-full blur-3xl group-hover:scale-150 transition-transform duration-700"></div>
						
						<div class="relative z-10">
							<div class="flex items-center gap-4 mb-6">
								<div class="bg-amber-500 text-white w-14 h-14 rounded-2xl flex items-center justify-center shadow-lg shadow-amber-500/30 text-2xl">
									🎡
								</div>
								<div>
									<h3 class="text-2xl font-black text-amber-950 tracking-tight">Autobús Especial Feria</h3>
									<p class="text-xs font-bold text-amber-700 uppercase tracking-widest mt-1">Servicio Temporal 2026</p>
								</div>
							</div>

							<p class="text-amber-900/80 mb-8 leading-relaxed font-medium">
								Durante la semana de la Feria de Abril de Sevilla, se habilita este servicio especial con paradas en Cantillana, Villaverde y Brenes.
							</p>

							<div class="grid grid-cols-1 sm:grid-cols-2 gap-8 bg-white/50 backdrop-blur-sm rounded-2xl p-6 border border-amber-200/50">
								<div>
									<div class="flex items-center gap-2 mb-4">
										<div class="w-2 h-2 bg-amber-500 rounded-full animate-pulse"></div>
										<p class="text-sm font-black text-amber-950 uppercase tracking-tight">Salidas Cantillana</p>
									</div>
									<ul class="space-y-3">
										<li class="flex justify-between items-center text-sm">
											<span class="text-amber-800 font-bold">Jueves 23:</span>
											<span class="bg-amber-100 px-3 py-1 rounded-lg text-amber-950 font-black">16:00h</span>
										</li>
										<li class="flex justify-between items-center text-sm">
											<span class="text-amber-800 font-bold">Viernes 24:</span>
											<span class="bg-amber-100 px-3 py-1 rounded-lg text-amber-950 font-black">16:00h y 23:00h</span>
										</li>
										<li class="flex justify-between items-center text-sm">
											<span class="text-amber-800 font-bold">Sábado 25:</span>
											<span class="bg-amber-100 px-3 py-1 rounded-lg text-amber-950 font-black">16:00h</span>
										</li>
									</ul>
								</div>
								<div class="border-t sm:border-t-0 sm:border-l border-amber-200/50 pt-6 sm:pt-0 sm:pl-8">
									<div class="flex items-center gap-2 mb-4">
										<div class="w-2 h-2 bg-orange-500 rounded-full animate-pulse"></div>
										<p class="text-sm font-black text-amber-950 uppercase tracking-tight">Regresos (Feria)</p>
									</div>
									<ul class="space-y-3">
										<li class="flex justify-between items-center text-sm">
											<span class="text-amber-800 font-bold">Vie 24:</span>
											<span class="bg-orange-100 px-3 py-1 rounded-lg text-orange-950 font-black">00:30h y 08:00h</span>
										</li>
										<li class="flex justify-between items-center text-sm">
											<span class="text-amber-800 font-bold">Sáb 25:</span>
											<span class="bg-orange-100 px-3 py-1 rounded-lg text-orange-950 font-black">00:30h y 06:00h</span>
										</li>
										<li class="flex justify-between items-center text-sm">
											<span class="text-amber-800 font-bold">Dom 26:</span>
											<span class="bg-orange-100 px-3 py-1 rounded-lg text-orange-950 font-black">01:00h</span>
										</li>
									</ul>
								</div>
							</div>
							
							<div class="mt-6 flex items-center gap-2 text-[10px] text-amber-700 font-bold uppercase tracking-widest bg-amber-100/50 w-fit px-4 py-2 rounded-full border border-amber-200/50">
								<span class="relative flex h-2 w-2">
									<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75"></span>
									<span class="relative inline-flex rounded-full h-2 w-2 bg-amber-500"></span>
								</span>
								Servicio independiente al M-216
							</div>
						</div>
					</div>
				</div>
			</div>
			<div
				id="content-minibus"
				class="tab-content transition-all duration-500 opacity-0 scale-95 hidden"
			>
				<BusCard bus={busData.minibus} />
			</div>
		</div>
	</section>
</Layout>

<script is:inline>
	function initSwitcher() {
		const switcherContainer = document.getElementById("transport-switcher");
		if (!switcherContainer) return;

		const tabContents = document.querySelectorAll(".tab-content");
		const buttons = switcherContainer.querySelectorAll(".switcher-btn");
		const indicator = switcherContainer.querySelector("#indicator");

		// Single listener on the container
		switcherContainer.onclick = (e) => {
			const btn = e.target.closest(".switcher-btn");
			if (!btn) return;

			const target = btn.getAttribute("data-target");

			// Update buttons
			buttons.forEach((b) => {
				b.classList.remove("active", "text-primary");
				b.classList.add("text-slate-500");
			});
			btn.classList.add("active", "text-primary");
			btn.classList.remove("text-slate-500");

			// Update content
			tabContents.forEach((content) => {
				if (content.id === `content-${target}`) {
					content.classList.remove("hidden", "opacity-0", "scale-95");
					content.classList.add("block", "opacity-100", "scale-100");
				} else {
					content.classList.add("hidden", "opacity-0", "scale-95");
					content.classList.remove("block", "opacity-100", "scale-100");
				}
			});

			// Update indicator position
			if (indicator) {
				indicator.style.transform = target === "minibus" ? "translateX(100%)" : "translateX(0%)";
			}
		};
	}

	// Initialize
	initSwitcher();
	
	// Prevent double listeners on global object
	if (!window.switcherEventSet) {
		const initFeriaCard = () => {
			const feriaCard = document.getElementById("feria-special-card");
			if (!feriaCard) return;

			const now = new Date();
			const FERIA_DATES = ['2026-04-21', '2026-04-22', '2026-04-23', '2026-04-24', '2026-04-25', '2026-04-26'];
			const todayStr = now.getFullYear() + '-' + String(now.getMonth() + 1).padStart(2, '0') + '-' + String(now.getDate()).padStart(2, '0');
			
			if (FERIA_DATES.includes(todayStr)) {
				feriaCard.classList.remove("hidden");
			} else {
				feriaCard.classList.add("hidden");
			}
		};

		initFeriaCard();

		document.addEventListener("astro:after-swap", () => {
			initSwitcher();
			initFeriaCard();
		});
		window.switcherEventSet = true;
	}
</script>

<style>
	.switcher-btn.active {
		color: #1b5e20 !important;
	}
	.tab-content {
		transition-property: opacity, transform;
	}
</style>
