---
import Layout from "../layouts/Layout.astro";
import BusCard from "../components/BusCard.astro";
import busData from "../data/buses.json";

export const prerender = true;
---

<Layout
	title="Transporte"
	description="Consulta horarios de autobuses de Cantillana en tiempo real con nuestra herramienta interactiva."
>
	<!-- Hero Section -->
	<section class="relative bg-primary overflow-hidden pt-36 pb-24 sm:pt-44 sm:pb-32 -mt-2">
		<div class="mx-auto max-w-7xl px-6 lg:px-8 text-center relative z-10">
			<div
				class="inline-flex items-center gap-2 rounded-full px-4 py-1.5 text-xs font-bold uppercase tracking-wider text-secondary bg-white/10 mb-8 border border-white/10 backdrop-blur-sm animate-fade"
			>
				Horarios Actualizados 2026
			</div>
			<h1
				class="text-4xl font-extrabold tracking-tight text-white sm:text-6xl mb-8 leading-tight"
			>
				Moverte por <span class="text-secondary">Cantillana</span><br
				/>nunca fue tan fácil
			</h1>
			<p
				class="mx-auto max-w-2xl text-lg opacity-90 text-slate-100 mb-10 leading-relaxed"
			>
				Consulta los horarios de las líneas que conectan nuestro pueblo con la estación y Sevilla. 
                Información oficial en tiempo real.
			</p>
			<div class="flex flex-col sm:flex-row gap-4 justify-center">
				<a
					href="#transporte"
					class="bg-secondary text-primary px-8 py-4 rounded-full font-bold shadow-xl shadow-secondary/20 hover:-translate-y-1 transition-all"
					>Ver Horarios</a
				>
				<a
					href="/"
					class="bg-white/10 text-white border border-white/20 backdrop-blur-md px-8 py-4 rounded-full font-bold hover:bg-white/20 transition-all"
					>Volver al Inicio</a
				>
			</div>
		</div>
		<!-- Decorative blobs -->
		<div
			class="absolute -top-24 -left-20 w-96 h-96 bg-secondary/10 rounded-full blur-3xl pointer-events-none"
		>
		</div>
		<div
			class="absolute -bottom-24 -right-20 w-96 h-96 bg-primary-light/30 rounded-full blur-3xl pointer-events-none"
		>
		</div>
	</section>

	<!-- Transport Section -->
	<section
		id="transporte"
		class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-20"
	>
		<div class="text-center mb-16 px-4">
			<h2 class="text-3xl font-extrabold text-primary mb-4">
				🚌 Transporte Público
			</h2>
			<p class="text-slate-500 max-w-xl mx-auto">
				Selecciona la línea para ver los horarios detallados de ida y vuelta.
			</p>
		</div>


		<!-- Switcher Moderno -->
		<div class="flex justify-center mb-12 animate-fade">
			<div
				class="relative flex p-1.5 bg-slate-200/50 backdrop-blur-md border border-slate-200 rounded-full w-fit shadow-inner group"
				id="transport-switcher"
			>
				<button
					class="relative z-20 flex-1 px-6 py-3 text-xs sm:text-sm font-bold transition-colors switcher-btn active cursor-pointer"
					data-target="m216">Bus M-216 (Sevilla)</button
				>
				<button
					class="relative z-20 flex-1 px-6 py-3 text-xs sm:text-sm font-bold transition-colors switcher-btn cursor-pointer"
					data-target="minibus">Minibús (Estación)</button
				>
				<!-- Botón especial Feria (derecha) -->
				<button
					id="feria-btn"
					class="relative z-20 flex-1 px-6 py-3 text-xs sm:text-sm font-bold transition-colors switcher-btn hidden cursor-pointer"
					data-target="feria">Feria</button
				>
				<div
					class="absolute top-1.5 left-1.5 bottom-1.5 w-[calc(50%-0.375rem)] bg-white rounded-full shadow-lg transition-all duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] switcher-indicator translate-x-0 pointer-events-none"
					id="indicator"
				>
				</div>
			</div>
		</div>

		<div class="space-y-10">
			<div
				id="content-m216"
				class="tab-content transition-all duration-500 opacity-100 scale-100 block"
			>
				<BusCard bus={busData.m216} />
			</div>

			<div
				id="content-minibus"
				class="tab-content transition-all duration-500 opacity-0 scale-95 hidden"
			>
				<BusCard bus={busData.minibus} />
			</div>

			<!-- Pestaña Especial Feria (Estilo BusCard) -->
			<div
				id="content-feria"
				class="tab-content transition-all duration-500 opacity-0 scale-95 hidden"
			>
				<div class="bg-white rounded-[2.5rem] p-6 sm:p-10 shadow-2xl shadow-slate-200/60 border border-slate-100 relative overflow-hidden" id="feria-card">
					<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-6 mb-10">
						<div class="flex items-center gap-5">
							<div class="w-16 h-16 bg-amber-100 rounded-2xl flex items-center justify-center text-3xl shadow-sm border border-amber-200/50">
								🎡
							</div>
							<div>
								<h3 class="text-2xl font-black text-slate-800 tracking-tight">Autobús Especial Feria</h3>
								<p class="text-xs font-bold text-amber-600 uppercase tracking-widest mt-1">Refuerzos Temporales 2026</p>
							</div>
						</div>
					</div>

					<!-- PRÓXIMO AUTOBÚS FERIA -->
					<div class="bg-linear-to-br from-amber-500 to-orange-600 rounded-[2rem] p-8 text-white mb-10 shadow-xl shadow-amber-500/20 relative overflow-hidden group">
						<div class="absolute top-0 right-0 p-8 opacity-10 group-hover:scale-110 transition-transform duration-700">
							<span class="text-8xl">🎡</span>
						</div>
						<div class="relative z-10 text-center">
							<span class="text-[10px] font-black uppercase tracking-[0.2em] opacity-80 mb-4 block">Próximo Autobús Especial</span>
							<div class="text-6xl font-black tracking-tighter mb-2 feria-next-time">--:--</div>
							<div class="text-sm font-medium opacity-90 feria-countdown">Calculando...</div>
						</div>
					</div>

					<!-- Selector de Dirección -->
					<div class="flex p-1.5 bg-slate-100 rounded-2xl mb-8 w-fit" id="feria-dir-switcher">
						<button class="px-5 py-2.5 text-xs font-bold rounded-xl transition-all active bg-white shadow-sm text-amber-700" data-dir="Cantillana ➔ Sevilla">
							Cantillana ➔ Sevilla
						</button>
						<button class="px-5 py-2.5 text-xs font-bold rounded-xl transition-all text-slate-500" data-dir="Sevilla ➔ Cantillana">
							Sevilla ➔ Cantillana
						</button>
					</div>

					<div class="grid grid-cols-1 md:grid-cols-2 gap-8 pt-8 border-t border-slate-100">
						<div class="space-y-4">
							<p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Información del Servicio</p>
							<p class="text-sm text-slate-600 leading-relaxed">
								Este es un servicio especial de feria. Consulta la tabla completa de horarios debajo si no hay buses próximos hoy.
							</p>
						</div>
						<div class="bg-amber-50 rounded-2xl p-6 border border-amber-100">
							<p class="text-xs font-bold text-amber-800 uppercase tracking-widest mb-4">Tabla Completa de Horarios</p>
							<div class="grid grid-cols-2 gap-4 text-[10px]">
								<div class="space-y-2">
									<p class="font-bold text-amber-900">Salidas:</p>
									<ul class="text-amber-800/80 space-y-1">
										<li>Jue 23: 16:00</li>
										<li>Vie 24: 16:00, 23:00</li>
										<li>Sáb 25: 16:00</li>
									</ul>
								</div>
								<div class="space-y-2">
									<p class="font-bold text-amber-900">Regresos:</p>
									<ul class="text-amber-800/80 space-y-1">
										<li>Vie 24: 00:30, 08:00</li>
										<li>Sáb 25: 00:30, 06:00</li>
										<li>Dom 26: 01:00</li>
									</ul>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
		</div>
	</div>
		</div>
	</section>
</Layout>

<script is:inline>
	function initSwitcher() {
		const switcherContainer = document.getElementById("transport-switcher");
		if (!switcherContainer) return;

		const tabContents = document.querySelectorAll(".tab-content");
		const buttons = Array.from(switcherContainer.querySelectorAll(".switcher-btn"));
		const indicator = switcherContainer.querySelector("#indicator");

		const updateIndicator = (target) => {
			if (!indicator) return;
			const visibleButtons = buttons.filter(b => !b.classList.contains('hidden'));
			const btnIndex = visibleButtons.findIndex(b => b.getAttribute('data-target') === target);
			if (btnIndex === -1) return;
			
			const width = 100 / visibleButtons.length;
			indicator.style.width = `calc(${width}% - 0.375rem)`;
			indicator.style.transform = `translateX(${btnIndex * 100}%)`;
		};

		switcherContainer.onclick = (e) => {
			const btn = e.target.closest(".switcher-btn");
			if (!btn) return;

			const target = btn.getAttribute("data-target");

			buttons.forEach((b) => {
				b.classList.remove("active", "text-primary");
				b.classList.add("text-slate-500");
			});
			btn.classList.add("active", "text-primary");
			btn.classList.remove("text-slate-500");

			tabContents.forEach((content) => {
				if (content.id === `content-${target}`) {
					content.classList.remove("hidden", "opacity-0", "scale-95");
					content.classList.add("block", "opacity-100", "scale-100");
				} else {
					content.classList.add("hidden", "opacity-0", "scale-95");
					content.classList.remove("block", "opacity-100", "scale-100");
				}
			});

			updateIndicator(target);
		};

		const activeBtn = buttons.find(b => b.classList.contains('active'));
		if (activeBtn) updateIndicator(activeBtn.getAttribute('data-target'));
	}

	function initFeriaCard() {
		const feriaBtn = document.getElementById("feria-btn");
		if (!feriaBtn) return;

		const now = new Date();
		const todayStr = now.getFullYear() + '-' + String(now.getMonth() + 1).padStart(2, '0') + '-' + String(now.getDate()).padStart(2, '0');
		const FERIA_DATES = ['2026-04-21', '2026-04-22', '2026-04-23', '2026-04-24', '2026-04-25', '2026-04-26'];
		
		if (FERIA_DATES.includes(todayStr)) {
			feriaBtn.classList.remove("hidden");
		} else {
			feriaBtn.classList.add("hidden");
		}
		
		initSwitcher();
		setupFeriaLogic();
	}

	function setupFeriaLogic() {
		const feriaCard = document.getElementById('feria-card');
		if (!feriaCard) return;

		const FERIA_SCHEDULE = {
			'2026-04-23': { 'Cantillana ➔ Sevilla': ['16:00'], 'Sevilla ➔ Cantillana': [] },
			'2026-04-24': { 'Cantillana ➔ Sevilla': ['16:00', '23:00'], 'Sevilla ➔ Cantillana': ['00:30', '08:00'] },
			'2026-04-25': { 'Cantillana ➔ Sevilla': ['16:00'], 'Sevilla ➔ Cantillana': ['00:30', '06:00'] },
			'2026-04-26': { 'Cantillana ➔ Sevilla': [], 'Sevilla ➔ Cantillana': ['01:00'] }
		};

		let currentFeriaDir = "Cantillana ➔ Sevilla";

		function updateFeriaTimes() {
			const now = new Date();
			const todayStr = now.getFullYear() + '-' + String(now.getMonth() + 1).padStart(2, '0') + '-' + String(now.getDate()).padStart(2, '0');
			const currentTimeMinutes = now.getHours() * 60 + now.getMinutes();
			
			const todaySchedule = FERIA_SCHEDULE[todayStr]?.[currentFeriaDir] || [];
			let nextTime = null;

			todaySchedule.forEach(timeStr => {
				const [h, m] = timeStr.split(':').map(Number);
				const busMinutes = h * 60 + m;
				if (busMinutes > currentTimeMinutes) {
					if (!nextTime || busMinutes < nextTime.minutes) {
						nextTime = { str: timeStr, minutes: busMinutes };
					}
				}
			});

			const timeDisplay = feriaCard.querySelector('.feria-next-time');
			const countdownDisplay = feriaCard.querySelector('.feria-countdown');

			if (nextTime) {
				timeDisplay.textContent = nextTime.str;
				const diff = nextTime.minutes - currentTimeMinutes;
				const h = Math.floor(diff / 60);
				const m = diff % 60;
				countdownDisplay.textContent = diff < 60 ? `en ${m} min` : `en ${h}h ${m}m`;
			} else {
				timeDisplay.textContent = "--:--";
				countdownDisplay.textContent = "No hay más buses hoy";
			}
		}

		// Direction switcher
		const dirButtons = document.querySelectorAll('#feria-dir-switcher button');
		dirButtons.forEach(btn => {
			btn.onclick = () => {
				dirButtons.forEach(b => {
					b.classList.remove('bg-white', 'shadow-sm', 'text-amber-700');
					b.classList.add('text-slate-500');
				});
				btn.classList.add('bg-white', 'shadow-sm', 'text-amber-700');
				btn.classList.remove('text-slate-500');
				currentFeriaDir = btn.getAttribute('data-dir');
				updateFeriaTimes();
			};
		});

		updateFeriaTimes();
		if (window.feriaInterval) clearInterval(window.feriaInterval);
		window.feriaInterval = setInterval(updateFeriaTimes, 30000);
	}

	initFeriaCard();

	if (!window.switcherEventSet) {
		document.addEventListener("astro:after-swap", () => {
			initFeriaCard();
		});
		window.switcherEventSet = true;
	}
</script>

<style>
	.switcher-btn.active {
		color: #1b5e20 !important;
	}
	.tab-content {
		transition-property: opacity, transform;
	}
</style>
