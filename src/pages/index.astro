---
import Layout from "../layouts/Layout.astro";

export const prerender = true;

const categories = [
	{
		title: "Transporte Público",
		description: "Horarios de autobuses M-216 y Minibús a la estación de tren.",
		icon: "🚌",
		link: "/transporte",
		color: "bg-blue-500",
		tag: "Horarios 2025"
	},
	{
		title: "Farmacias",
		description: "Encuentra la farmacia de guardia abierta hoy en Cantillana.",
		icon: "💊",
		link: "/farmacia",
		color: "bg-emerald-500",
		tag: "Guardia Hoy"
	},
	{
		title: "Punto Limpio",
		description: "Recogida de residuos, horarios y ubicación del centro de reciclaje.",
		icon: "♻️",
		link: "/punto-limpio",
		color: "bg-amber-500",
		tag: "Gestión"
	}
];
---

<Layout
	title="Inicio"
	description="Portal de información digital para los vecinos de Cantillana: transporte, farmacias, punto limpio y más."
>
	<!-- Hero Section -->
	<section class="relative bg-primary overflow-hidden pt-36 pb-20 sm:pt-48 sm:pb-32 -mt-2">
		<div class="mx-auto max-w-7xl px-6 lg:px-8 text-center relative z-10">
			<div
				class="inline-flex items-center gap-2 rounded-full px-4 py-1.5 text-xs font-bold uppercase tracking-wider text-secondary bg-white/10 mb-8 border border-white/10 backdrop-blur-sm animate-fade"
			>
				Tu pueblo en formato digital
			</div>
			<h1
				class="text-5xl font-extrabold tracking-tight text-white sm:text-7xl mb-8 leading-tight"
			>
				Toda la información de <span class="text-secondary italic">Cantillana</span> 
                <span class="block mt-2">en un solo lugar</span>
			</h1>
			<p
				class="mx-auto max-w-2xl text-xl opacity-90 text-slate-100 mb-12 leading-relaxed"
			>
				Accede de forma rápida y sencilla a los horarios de transporte, farmacias de guardia 
                y servicios municipales actualizados para todos los vecinos.
			</p>
			<div class="flex flex-col sm:flex-row gap-6 justify-center">
				<a
					href="#servicios"
					class="btn-primary py-4 px-10 text-lg shadow-2xl shadow-primary/40"
					>Explorar Servicios</a
				>
			</div>
		</div>
		<!-- Decorative Background -->
		<div class="absolute inset-0 z-0">
			<div class="absolute top-0 left-0 w-full h-full bg-gradient-to-b from-primary via-primary to-transparent opacity-90"></div>
			<div class="absolute -top-24 -left-20 w-[600px] h-[600px] bg-secondary/20 rounded-full blur-[120px] pointer-events-none"></div>
			<div class="absolute bottom-0 right-0 w-[500px] h-[500px] bg-primary-light/40 rounded-full blur-[100px] pointer-events-none"></div>
		</div>
	</section>

	<!-- Categories/Services Section -->
	<section id="servicios" class="relative z-10 mt-24 px-6 pb-32">
		<div class="mx-auto max-w-7xl">
			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				{categories.map((cat, index) => (
					<a 
						href={cat.link} 
						class="group relative block bg-white rounded-3xl p-8 shadow-xl shadow-slate-200/50 hover:shadow-2xl hover:shadow-primary/10 transition-all duration-500 hover:-translate-y-2 border border-slate-100 overflow-hidden"
					>
						<!-- Decorative icon background -->
						<div class={`absolute -top-10 -right-10 w-32 h-32 ${cat.color} opacity-[0.03] rounded-full group-hover:scale-150 transition-transform duration-700`}></div>
						
						<div class="flex justify-between items-start mb-10">
							<div class={`text-4xl p-4 rounded-2xl ${cat.color} bg-opacity-10 group-hover:scale-110 transition-transform`}>
								{cat.icon}
							</div>
							<span class="text-[10px] font-bold uppercase tracking-widest text-slate-400 bg-slate-50 px-3 py-1 rounded-full border border-slate-100">
								{cat.tag}
							</span>
						</div>
						
						<h3 class="text-2xl font-bold text-slate-900 mb-3 group-hover:text-primary transition-colors">
							{cat.title}
						</h3>
						<p class="text-slate-500 leading-relaxed mb-8">
							{cat.description}
						</p>
						
						<div class="flex items-center gap-2 text-primary font-bold text-sm">
							Consultar ahora 
							<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
							</svg>
						</div>
					</a>
				))}
			</div>

            <!-- Stats/Motivation -->
            <div class="mt-40 mb-20 relative px-4">
                <div class="absolute inset-0 bg-primary/5 blur-[100px] -z-10 rounded-full max-w-4xl mx-auto"></div>
                
                <h2 class="text-4xl md:text-5xl font-black text-slate-900 text-center mb-24 tracking-tight">
                    ¿Por qué usar <span class="text-primary relative inline-block">Cantillana Digital<div class="absolute -bottom-2 left-0 w-full h-1 bg-primary/20 rounded-full"></div></span>?
                </h2>
                
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
                    {[
                        { label: "Horarios Reales", desc: "Datos actualizados mensualmente", icon: "⏱️", color: "bg-blue-500" },
                        { label: "Todo en Uno", desc: "No más búsquedas infinitas", icon: "📱", color: "bg-purple-500" },
                        { label: "Optimizado", desc: "Carga rápida en móviles", icon: "🚀", color: "bg-orange-500" },
                        { label: "Local", desc: "Información 100% de nuestro pueblo", icon: "📍", color: "bg-rose-500" }
                    ].map((stat, idx) => (
                        <div class="glass-panel group p-8 text-center hover:bg-white transition-all duration-500 hover:-translate-y-2 border-slate-100 hover:border-primary/20">
                            <div class="relative inline-block mb-6">
                                <div class={`absolute inset-0 ${stat.color} opacity-20 blur-xl rounded-full group-hover:scale-150 transition-transform duration-700`}></div>
                                <div class={`relative text-5xl transform group-hover:scale-110 group-hover:rotate-12 transition-transform duration-500`}>
                                    {stat.icon}
                                </div>
                            </div>
                            <h4 class="text-xl font-bold text-slate-900 mb-2 group-hover:text-primary transition-colors">{stat.label}</h4>
                            <p class="text-[15px] text-slate-500 leading-relaxed font-medium">
                                {stat.desc}
                            </p>
                        </div>
                    ))}
                </div>
            </div>
		</div>
	</section>
</Layout>
